# ═══════════════════════════════════════════════════════════
# AFIA HEALTH ASSISTANT — Environment Configuration
# SaaS + Hybrid Offline Model
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Security (GENERATE NEW VALUES FOR PRODUCTION) ───────────
SECRET_KEY=your-32-byte-secret-key-here-change-me
# Generate: openssl rand -hex 32

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=afia_admin
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=afia_health
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379

# ── Qdrant (Vector Database) ───────────────────────────────
QDRANT_API_KEY=change_this_qdrant_api_key
QDRANT_PORT=6333

# ── MinIO (File Storage) ───────────────────────────────────
MINIO_ROOT_USER=afia_minio
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── API ────────────────────────────────────────────────────
API_PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=480      # 8 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (Your frontend domains) ───────────────────────────
CORS_ORIGINS=http://localhost:3000,https://app.afia.health,https://afia.health

# ── Backup (Optional S3 for off-site backups) ──────────────
BACKUP_S3_BUCKET=afia-backups
BACKUP_AWS_KEY=your-aws-access-key
BACKUP_AWS_SECRET=your-aws-secret-key
BACKUP_S3_ENDPOINT=s3.amazonaws.com

# ── Stripe/Billing (When ready) ──────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email (For notifications, password resets) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@afia.health
SMTP_PASSWORD=your-app-password

# ── Encryption (Field-level for patient PII) ───────────────
FIELD_ENCRYPTION_KEY=your-32-byte-field-encryption-key
# Generate: openssl rand -hex 32 (DIFFERENT from SECRET_KEY)

#App login details
ADMIN_EMAIL=admin@afia.health
ADMIN_NAME=admin
ADMIN_PASSWORD=Admin1234!